<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # If the request is for a real file or directory that exists, serve it
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Handle PHP files normally
    RewriteCond %{REQUEST_URI} \.php$
    RewriteRule ^ - [L]

    # For everything else, serve the React index.html
    # This allows the React Router to handle deep links
    RewriteRule ^ index.html [L]
</IfModule>
